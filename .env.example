# ──────────────────────────────────────────────────────────────
# Big Berlin Hackathon — Team noTime | Environment template
# ──────────────────────────────────────────────────────────────
# NEVER commit `.env` or paste real secrets into GitHub. This file is safe
# to commit; copy it locally and fill in values:
#   cp .env.example .env
#
# `DEEPGRAM_API_KEY` is required by config.py at startup (even if calls use
# ElevenLabs only). See README.md for full stack and Twilio/ngrok steps.
# ──────────────────────────────────────────────────────────────

# Required - get a free key at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Server settings (defaults shown)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080

# Public URL where Twilio can reach this server. Set automatically by
# `python setup.py`. Only set this manually if you're using a tunnel
# (ngrok, zrok) instead of the setup wizard.
# SERVER_EXTERNAL_URL=

# Voice agent model settings (defaults shown)
# VOICE_MODEL=aura-2-thalia-en
# LLM_MODEL=gpt-4o-mini

# --- Twilio (run `python setup.py` to configure, or set manually) ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Use EITHER Auth Token OR API Key (REST tools often use API key):
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+4930xxxxxxxx

# --- ElevenLabs ConvAI (inbound calls use this; sync prompt with fnol_sync) ---
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=
# ELEVENLABS_VOICE_ID=Jvf6TAXwMUVTSR20U0f9
# ELEVENLABS_TTS_MODEL=eleven_v3_conversational
# (eleven_flash_v2 = faster, no v3 audio tags — fnol_sync sets expressive_mode=false automatically)
# ELEVENLABS_COMPANY_NAME=INCA Insurance
# ELEVENLABS_TTS_STABILITY=0.45
# ELEVENLABS_TTS_SIMILARITY_BOOST=0.78
# ELEVENLABS_TTS_SPEED=0.97
# ELEVENLABS_STREAMING_LATENCY=2
# Push agent:  python3 -m voice_agent.elevenlabs_fnol_sync
# List voices:  python3 -m voice_agent.elevenlabs_voice_check

# --- OpenAI (post-call dashboard extraction) ---
# OPENAI_API_KEY=
# CLAIM_EXTRACTION_MODEL=gpt-4o-mini

# --- Security (set automatically by setup.py on Fly.io deploy) ---
# WEBHOOK_SECRET=

# --- Dashboard (inca-dashboard/.env.local — not read by Python) ---
# NEXT_PUBLIC_WS_URL=ws://localhost:8989/ws

# --- Pioneer (Fastino) — optional offline NER / hackathon track; NOT used by main.py ---
# https://pioneer.ai/ — keys typically start with pio_sk_
# PIONEER_API_KEY=
# PIONEER_MODEL_ID=fastino/gliner2-base-v1
# Demo:  python3 -m integrations   (optional: --stdin / --file claim.json)
