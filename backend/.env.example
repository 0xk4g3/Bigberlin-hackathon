# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
APP_HOST=https://claimcall.yourdomain.com   # Public URL used in TwiML Stream URL
ENVIRONMENT=production                       # development | production
LOG_LEVEL=INFO

# ── Twilio ──────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+49xxxxxxxxx
TWILIO_VALIDATE_REQUESTS=true               # Set false in development

# ── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_AGENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Rotate before production

# ── AI-Coustics ─────────────────────────────────────────────────────────────
# SDK package: aic-sdk (pip install aic-sdk)
# This key is passed as AIC_SDK_LICENSE to the aic_sdk library
AICOUSTICS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AICOUSTICS_ENABLED=true                     # Set false to bypass (raw audio passthrough)

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# MUST be the service_role key (not anon key) — Project Settings → API → service_role
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Audio Settings ───────────────────────────────────────────────────────────
APPLY_TELEPHONE_FILTER=true                 # Bandpass 300Hz–3.4kHz on EL output audio
TELEPHONE_FILTER_ORDER=4                    # Butterworth filter order

# ── Notifications ────────────────────────────────────────────────────────────
CLAIMS_MANAGER_PHONE=+49xxxxxxxxx           # SMS alerts for critical urgency / SIU flags
CLAIMS_MANAGER_EMAIL=claims@yourcompany.com
